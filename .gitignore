# Godot editor/cache
.godot/

# Godot 4.4+ regenerates a *.uid sidecar per script on every editor/import pass (e.g.
# run_tests.sh's class-cache regen) — ~200 untracked files that are easy to sweep into a commit
# by accident (#181). Ignore them all; git keeps the 3 intentionally-tracked ones tracked
# regardless (NcnnAgent.gd.uid, addons/.../ncnn_runner.gdextension.uid, node_2d.gd.uid).
*.uid

# Local build artifacts
addons/godot_native_rl/bin/
*.os
*.o
.sconsign.dblite

# Local dependencies (built/managed outside this repo)
godot-cpp/
thirdparty/

# Python env/cache
.venv/
__pycache__/
models/__pycache__/
models/*.pt
models/*.pt.shape.json
models/*.onnx
models/*.onnx.data
models/*.pnnx.*
models/*_ncnn.py
models/*_pnnx.py

# Part 2B training
.venv-train/
logs/
models/chase_policy.*
models/rover_checkpoints/
